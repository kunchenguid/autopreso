{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "packages": {
    ".": {
      "release-type": "node",
      "package-name": "autopreso",
      "extra-files": [
        {
          "type": "json",
          "path": "packages/moonshine-darwin-arm64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/moonshine-darwin-x64/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.optionalDependencies['@autopreso/moonshine-darwin-arm64']"
        },
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.optionalDependencies['@autopreso/moonshine-darwin-x64']"
        }
      ]
    }
  }
}
